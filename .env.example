# ─── Claude (Anthropic) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Model to use for the tutor orchestrator (e.g. claude-sonnet-4-20250514)
CLAUDE_MODEL=claude-sonnet-4-20250514

# ─── Text-to-Speech (TTS) ──────────────────────────────────────────
# Provider: "openai" | "elevenlabs"
TTS_PROVIDER=openai

# OpenAI TTS
OPENAI_API_KEY=sk-...
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova

# ElevenLabs TTS
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ─── Speech-to-Text (STT) ──────────────────────────────────────────
# Provider: "openai" (Whisper)
STT_PROVIDER=openai
# Reuses OPENAI_API_KEY above
STT_LANGUAGE=es

# ─── App ────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
